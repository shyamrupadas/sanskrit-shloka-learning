NODE_ENV=development
# Runtime API connections can use a pooled database URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER/DATABASE?sslmode=require"
# Maximum application-side connections per API replica. Increase only from measured pool pressure.
DATABASE_POOL_MAX=5
# Production migrations require a direct database URL. For Neon, copy it from the dashboard.
# Local development may omit this value; migrations then use DATABASE_URL unchanged.
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
FRONTEND_ORIGIN="http://localhost:5173"
PORT=3000
